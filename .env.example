# ============================================================
# Azure AI Chat — Variables de entorno
# Copia este fichero a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ── Base de datos PostgreSQL local (Docker) ──────────────────
POSTGRES_USER=pgadmin
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=postgres

# ── Base de datos PostgreSQL (Azure) ────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_bd?sslmode=require
# Nota: si el usuario contiene '@', codifícalo como '%40'
DATABASE_URL=postgresql://usuario:password@servidor.postgres.database.azure.com:5432/chatdb?sslmode=require

# ── Azure OpenAI ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=tu-api-key-aqui
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4

# ── Configuración general ────────────────────────────────────
APP_NAME=Azure AI Chat
DEBUG=false

# ── Prompt del sistema (opcional, valor por defecto incluido) ─
# SYSTEM_PROMPT=Eres un asistente de IA útil, claro y conciso. Responde en el mismo idioma que el usuario.
